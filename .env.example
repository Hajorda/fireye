# Copy this file to .env and fill in your values
# Never commit .env to git

# HuggingFace write token (get from https://huggingface.co/settings/tokens)
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxx

# Kaggle API credentials (get from https://www.kaggle.com/settings/account -> API -> Create New Token)
KAGGLE_USERNAME=your_kaggle_username
KAGGLE_KEY=your_kaggle_api_key

# HuggingFace repo names (change if you want different names)
HF_DATASET_REPO=hajorda/fireye-wildfire-detection
HF_MODEL_REPO=hajorda/fireye-yolov8m
